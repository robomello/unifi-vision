# UniFi OS console and local account
UNIFI_HOST=https://192.168.1.1
UNIFI_USER=unifi-vision-readonly
UNIFI_PASS=change-me
UNIFI_SITE=default

# MQTT broker used by Home Assistant
MQTT_HOST=192.168.1.2
MQTT_PORT=1883
MQTT_USER=unifi-vision
MQTT_PASS=change-me

# Optional: comma-separated MAC addresses; empty publishes every switch/UDM
SWITCH_MACS=
POLL_SEC=5
DISCOVERY_PREFIX=homeassistant
STATE_PREFIX=unifi-vision
